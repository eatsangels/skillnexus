{
  "name": "skillnexus-desktop",
  "version": "1.0.21",
  "description": "Desktop version of SkillNexus Dashboard",
  "main": "electron-main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eatsangels/skillnexus.git"
  },
  "author": "eatsangels",
  "scripts": {
    "dev:web": "powershell -File ./skill-dashboard/start.ps1",
    "dev:electron": "concurrently \"node skill-dashboard/backend/src/server.js\" \"npm --prefix skill-dashboard/frontend run dev\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=true electron .\"",
    "build:frontend": "npm --prefix skill-dashboard/frontend run build",
    "package:dir": "npm run build:frontend && electron-packager . \"SkillNexus\" --platform=win32 --arch=x64 --out=dist-desktop --overwrite --icon=skill-dashboard/frontend/public/logo.png",
    "package:dist": "npm run build:frontend && electron-builder"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "@vitalets/google-translate-api": "^9.2.1",
    "adm-zip": "^0.5.16",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "gray-matter": "^4.0.3"
  },
  "build": {
    "appId": "com.eatsangels.skillnexus",
    "productName": "SkillNexus",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron-main.js",
      "skill-dashboard/backend/src/**/*",
      "skill-dashboard/backend/node_modules/**/*",
      "skill-dashboard/backend/package.json",
      "skill-dashboard/frontend/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "skill-dashboard/frontend/public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SkillNexus"
    },
    "publish": {
      "provider": "github",
      "owner": "eatsangels",
      "repo": "skillnexus"
    }
  }
}
